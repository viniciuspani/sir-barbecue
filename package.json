{
  "name": "sir-barbecue",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "deploy:dev": "eas build --profile development --platform android",
    "deploy:preview": "eas build --profile preview --platform android",
    "deploy:production": "eas build --profile production --platform android",
    "prebuild": "expo prebuild --clean",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\""
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~55.0.0",
    "expo-auth-session": "~55.0.16",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-sharing": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@morrowdigital/watermelondb-expo-plugin": "^2.3.3",
    "@types/react": "~19.2.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "prettier": "^3.8.4",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "comment": "WatermelonDB e 'Untested on New Architecture' no RN Directory — risco conhecido, validado pelo spike no device (gate da Fase 0). Ver docs/plano/ANALISE_IMPACTO_EXPO_SDK_55.html.",
        "exclude": [
          "@nozbe/watermelondb",
          "@nozbe/simdjson"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
